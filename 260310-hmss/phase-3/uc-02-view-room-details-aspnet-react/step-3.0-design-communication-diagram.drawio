<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="UC-02 Design Communication Diagram">
    <mxGraphModel grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1350" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===================== PARTICIPANTS ===================== -->

        <!-- Visitor (primary actor) -->
        <mxCell id="actor-visitor" value="Visitor"
          style="shape=umlActor;whiteSpace=wrap;html=1;fillColor=#82CAFA;strokeColor=#000000;verticalLabelPosition=bottom;verticalAlign=top;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="320" width="50" height="80" as="geometry"/>
        </mxCell>

        <!-- VisitorUI -->
        <mxCell id="obj-visitorui"
          value="&#171;user interaction&#187;&lt;br/&gt;: VisitorUI"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#93c5fd;align=center;verticalAlign=middle;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="160" y="315" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- RoomDetailController -->
        <mxCell id="obj-controller"
          value="&#171;coordinator&#187;&lt;br/&gt;: RoomDetailController"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#fdba74;align=center;verticalAlign=middle;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="450" y="315" width="210" height="70" as="geometry"/>
        </mxCell>

        <!-- IRoomListingRepository -->
        <mxCell id="obj-repo"
          value="&#171;database wrapper&#187;&lt;br/&gt;: IRoomListingRepository"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dff6fb;strokeColor=#7dd3c7;align=center;verticalAlign=middle;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="790" y="185" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- IGoogleMapsGateway -->
        <mxCell id="obj-gateway"
          value="&#171;proxy&#187;&lt;br/&gt;: IGoogleMapsGateway"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#f9a8d4;align=center;verticalAlign=middle;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="790" y="450" width="210" height="70" as="geometry"/>
        </mxCell>

        <!-- Google Maps (secondary actor) -->
        <mxCell id="actor-googlemaps" value="Google Maps"
          style="shape=umlActor;whiteSpace=wrap;html=1;fillColor=#82CAFA;strokeColor=#000000;verticalLabelPosition=bottom;verticalAlign=top;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="1100" y="450" width="50" height="80" as="geometry"/>
        </mxCell>

        <!-- ===================== STRUCTURAL ASSOCIATIONS ===================== -->

        <mxCell id="assoc-visitor-visitorui"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeColor=#000000;"
          edge="1" source="actor-visitor" target="obj-visitorui" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="assoc-visitorui-controller"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeColor=#000000;"
          edge="1" source="obj-visitorui" target="obj-controller" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="assoc-controller-repo"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeColor=#000000;"
          edge="1" source="obj-controller" target="obj-repo" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="assoc-controller-gateway"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeColor=#000000;"
          edge="1" source="obj-controller" target="obj-gateway" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="assoc-gateway-googlemaps"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeColor=#000000;"
          edge="1" source="obj-gateway" target="actor-googlemaps" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===================== MESSAGES — GROUP 1 ===================== -->

        <!-- 1: Visitor -> VisitorUI: selectRoomListing(in listingId: Guid) -->
        <mxCell id="msg-1-text"
          value="1: selectRoomListing(in listingId: Guid)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="260" width="240" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="msg-1-arrow"
          style="edgeStyle=none;rounded=0;html=1;endArrow=classic;startArrow=none;strokeColor=#000000;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="55" y="280" as="sourcePoint"/>
            <mxPoint x="100" y="280" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 1.1: VisitorUI -> RoomDetailController: getRoomDetail(...) -->
        <mxCell id="msg-1-1-text"
          value="1.1: getRoomDetail(in listingId: Guid, out response: RoomDetailResponseDto)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="160" y="245" width="310" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="msg-1-1-arrow"
          style="edgeStyle=none;rounded=0;html=1;endArrow=classic;startArrow=none;strokeColor=#000000;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="415" y="268" as="sourcePoint"/>
            <mxPoint x="460" y="268" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 1.2: RoomDetailController -> IRoomListingRepository: findById(...) -->
        <mxCell id="msg-1-2-text"
          value="1.2: findById(in listingId: Guid, out listing: RoomListing)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="665" y="195" width="290" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="msg-1-2-arrow"
          style="edgeStyle=none;rounded=0;html=1;endArrow=classic;startArrow=none;strokeColor=#000000;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="690" y="215" as="sourcePoint"/>
            <mxPoint x="735" y="215" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===================== MESSAGES — GROUP 2 ===================== -->

        <!-- 2: Visitor -> VisitorUI: requestMapLocation() -->
        <mxCell id="msg-2-text"
          value="2: requestMapLocation()"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="400" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="msg-2-arrow"
          style="edgeStyle=none;rounded=0;html=1;endArrow=classic;startArrow=none;strokeColor=#000000;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="55" y="416" as="sourcePoint"/>
            <mxPoint x="100" y="416" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 2.1: VisitorUI -> RoomDetailController: getPropertyMap(...) -->
        <mxCell id="msg-2-1-text"
          value="2.1: getPropertyMap(in address: String, out response: PropertyMapResponseDto)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="160" y="392" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="msg-2-1-arrow"
          style="edgeStyle=none;rounded=0;html=1;endArrow=classic;startArrow=none;strokeColor=#000000;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="415" y="418" as="sourcePoint"/>
            <mxPoint x="460" y="418" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 2.2: RoomDetailController -> IGoogleMapsGateway: getLocationData(...) -->
        <mxCell id="msg-2-2-text"
          value="2.2: getLocationData(in address: String, out mapData: MapData)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="660" y="415" width="290" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="msg-2-2-arrow"
          style="edgeStyle=none;rounded=0;html=1;endArrow=classic;startArrow=none;strokeColor=#000000;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="685" y="437" as="sourcePoint"/>
            <mxPoint x="730" y="437" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 2.3: IGoogleMapsGateway -> Google Maps: getLocationData(...) -->
        <mxCell id="msg-2-3-text"
          value="2.3: getLocationData(in address: String, out mapData: MapData)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="790" y="530" width="290" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="msg-2-3-arrow"
          style="edgeStyle=none;rounded=0;html=1;endArrow=classic;startArrow=none;strokeColor=#000000;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="820" y="552" as="sourcePoint"/>
            <mxPoint x="865" y="552" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
