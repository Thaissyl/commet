<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="UC-02 Design Class Diagram">
    <mxGraphModel grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1500" pageHeight="1000">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===================== CLASS BOXES ===================== -->

        <!-- VisitorUI — user interaction -->
        <mxCell id="class-visitorui"
          value="&lt;table border=&quot;1&quot; cellspacing=&quot;0&quot; cellpadding=&quot;6&quot; style=&quot;width:100%;height:100%;border-collapse:collapse;font-size:12px;border-color:#93c5fd;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; bgcolor=&quot;#dbeafe&quot;&gt;&lt;font color=&quot;#1d4ed8&quot;&gt;&lt;b&gt;&#171;user interaction&#187;&lt;br/&gt;VisitorUI&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#f8fbff&quot;&gt;- (none)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#f8fbff&quot;&gt;+ selectRoomListing(in listingId: Guid)&lt;br/&gt;+ requestMapLocation()&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;"
          style="shape=rect;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=fill;spacing=0;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="270" height="120" as="geometry"/>
        </mxCell>

        <!-- RoomDetailController — coordinator -->
        <mxCell id="class-controller"
          value="&lt;table border=&quot;1&quot; cellspacing=&quot;0&quot; cellpadding=&quot;6&quot; style=&quot;width:100%;height:100%;border-collapse:collapse;font-size:12px;border-color:#fdba74;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; bgcolor=&quot;#ffedd5&quot;&gt;&lt;font color=&quot;#c2410c&quot;&gt;&lt;b&gt;&#171;coordinator&#187;&lt;br/&gt;RoomDetailController&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#fff7ed&quot;&gt;- (none)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#fff7ed&quot;&gt;+ getRoomDetail(in listingId: Guid, out response: RoomDetailResponseDto)&lt;br/&gt;+ getPropertyMap(in address: String, out response: PropertyMapResponseDto)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;"
          style="shape=rect;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=fill;spacing=0;"
          vertex="1" parent="1">
          <mxGeometry x="380" y="310" width="330" height="130" as="geometry"/>
        </mxCell>

        <!-- IRoomListingRepository — database wrapper -->
        <mxCell id="class-repo"
          value="&lt;table border=&quot;1&quot; cellspacing=&quot;0&quot; cellpadding=&quot;6&quot; style=&quot;width:100%;height:100%;border-collapse:collapse;font-size:12px;border-color:#7dd3c7;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; bgcolor=&quot;#dff6fb&quot;&gt;&lt;font color=&quot;#0f766e&quot;&gt;&lt;b&gt;&#171;database wrapper&#187;&lt;br/&gt;IRoomListingRepository&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#f7fcfd&quot;&gt;- (none)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#f7fcfd&quot;&gt;+ findById(in listingId: Guid, out listing: RoomListing)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;"
          style="shape=rect;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=fill;spacing=0;"
          vertex="1" parent="1">
          <mxGeometry x="790" y="130" width="320" height="100" as="geometry"/>
        </mxCell>

        <!-- RoomListing — data abstraction -->
        <mxCell id="class-roomlisting"
          value="&lt;table border=&quot;1&quot; cellspacing=&quot;0&quot; cellpadding=&quot;6&quot; style=&quot;width:100%;height:100%;border-collapse:collapse;font-size:12px;border-color:#7dd3c7;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; bgcolor=&quot;#dff6fb&quot;&gt;&lt;font color=&quot;#0f766e&quot;&gt;&lt;b&gt;&#171;data abstraction&#187;&lt;br/&gt;RoomListing&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#f7fcfd&quot;&gt;- listingId: Guid&lt;br/&gt;- propertyId: Guid&lt;br/&gt;- title: String&lt;br/&gt;- description: String&lt;br/&gt;- price: Decimal&lt;br/&gt;- capacity: Integer&lt;br/&gt;- amenities: String&lt;br/&gt;- availableFrom: Date&lt;br/&gt;- furnishedStatus: Boolean&lt;br/&gt;- privateWCStatus: Boolean&lt;br/&gt;- imagesRef: String&lt;br/&gt;- status: String&lt;br/&gt;- propertyName: String&lt;br/&gt;- propertyAddress: String&lt;br/&gt;- createdAt: DateTime&lt;br/&gt;- updatedAt: DateTime&lt;br/&gt;- publishedAt: DateTime&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#f7fcfd&quot;&gt;(none in current scope)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;"
          style="shape=rect;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=fill;spacing=0;"
          vertex="1" parent="1">
          <mxGeometry x="790" y="290" width="290" height="420" as="geometry"/>
        </mxCell>

        <!-- IGoogleMapsGateway — proxy -->
        <mxCell id="class-gateway"
          value="&lt;table border=&quot;1&quot; cellspacing=&quot;0&quot; cellpadding=&quot;6&quot; style=&quot;width:100%;height:100%;border-collapse:collapse;font-size:12px;border-color:#f9a8d4;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; bgcolor=&quot;#fce7f3&quot;&gt;&lt;font color=&quot;#be185d&quot;&gt;&lt;b&gt;&#171;proxy&#187;&lt;br/&gt;IGoogleMapsGateway&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#fff7fb&quot;&gt;- (none)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#fff7fb&quot;&gt;+ getLocationData(in address: String, out mapData: MapData)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;"
          style="shape=rect;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=fill;spacing=0;"
          vertex="1" parent="1">
          <mxGeometry x="790" y="780" width="300" height="100" as="geometry"/>
        </mxCell>

        <!-- MapData — data abstraction -->
        <mxCell id="class-mapdata"
          value="&lt;table border=&quot;1&quot; cellspacing=&quot;0&quot; cellpadding=&quot;6&quot; style=&quot;width:100%;height:100%;border-collapse:collapse;font-size:12px;border-color:#7dd3c7;&quot;&gt;&lt;tr&gt;&lt;td align=&quot;center&quot; bgcolor=&quot;#dff6fb&quot;&gt;&lt;font color=&quot;#0f766e&quot;&gt;&lt;b&gt;&#171;data abstraction&#187;&lt;br/&gt;MapData&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#f7fcfd&quot;&gt;- rawResponse: String&lt;br/&gt;- latitude: Decimal&lt;br/&gt;- longitude: Decimal&lt;br/&gt;- embedUrl: String&lt;br/&gt;- isAvailable: Boolean&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;left&quot; bgcolor=&quot;#f7fcfd&quot;&gt;(none in current scope)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;"
          style="shape=rect;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=fill;spacing=0;"
          vertex="1" parent="1">
          <mxGeometry x="1180" y="780" width="270" height="160" as="geometry"/>
        </mxCell>

        <!-- ===================== RELATIONSHIPS ===================== -->

        <!-- VisitorUI -> RoomDetailController: calls -->
        <mxCell id="edge-visitorui-controller"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;strokeWidth=1.4;endArrow=open;endFill=0;endSize=10;"
          edge="1" source="class-visitorui" target="class-controller" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="label-visitorui-controller"
          value="calls &gt;"
          style="text;html=1;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#334155;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="305" y="365" width="60" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="mult-visitorui-controller-src"
          value="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#475569;"
          vertex="1" parent="1">
          <mxGeometry x="336" y="380" width="24" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="mult-visitorui-controller-tgt"
          value="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#475569;"
          vertex="1" parent="1">
          <mxGeometry x="378" y="380" width="24" height="20" as="geometry"/>
        </mxCell>

        <!-- RoomDetailController -> IRoomListingRepository: uses -->
        <mxCell id="edge-controller-repo"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;strokeWidth=1.4;endArrow=open;endFill=0;endSize=10;"
          edge="1" source="class-controller" target="class-repo" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="label-controller-repo"
          value="uses &gt;"
          style="text;html=1;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#334155;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="730" y="180" width="60" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="mult-controller-repo-src"
          value="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#475569;"
          vertex="1" parent="1">
          <mxGeometry x="722" y="305" width="24" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="mult-controller-repo-tgt"
          value="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#475569;"
          vertex="1" parent="1">
          <mxGeometry x="746" y="218" width="24" height="20" as="geometry"/>
        </mxCell>

        <!-- IRoomListingRepository -> RoomListing: loads -->
        <mxCell id="edge-repo-roomlisting"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;strokeWidth=1.4;endArrow=open;endFill=0;endSize=10;"
          edge="1" source="class-repo" target="class-roomlisting" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="label-repo-roomlisting"
          value="loads &gt;"
          style="text;html=1;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#334155;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="860" y="250" width="60" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="mult-repo-roomlisting-src"
          value="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#475569;"
          vertex="1" parent="1">
          <mxGeometry x="925" y="240" width="24" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="mult-repo-roomlisting-tgt"
          value="0..*"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#475569;"
          vertex="1" parent="1">
          <mxGeometry x="915" y="278" width="36" height="20" as="geometry"/>
        </mxCell>

        <!-- RoomDetailController -> IGoogleMapsGateway: queries -->
        <mxCell id="edge-controller-gateway"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;strokeWidth=1.4;endArrow=open;endFill=0;endSize=10;"
          edge="1" source="class-controller" target="class-gateway" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="545" y="490"/>
              <mxPoint x="545" y="830"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="label-controller-gateway"
          value="queries &gt;"
          style="text;html=1;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#334155;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="495" y="660" width="70" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="mult-controller-gateway-src"
          value="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#475569;"
          vertex="1" parent="1">
          <mxGeometry x="534" y="608" width="24" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="mult-controller-gateway-tgt"
          value="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#475569;"
          vertex="1" parent="1">
          <mxGeometry x="534" y="812" width="24" height="20" as="geometry"/>
        </mxCell>

        <!-- IGoogleMapsGateway -> MapData: constructs -->
        <mxCell id="edge-gateway-mapdata"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;strokeWidth=1.4;endArrow=open;endFill=0;endSize=10;"
